    <UserControl x:Class="Siemens.Simatic.S7.Webserver.API.WebApplicationManager.CustomControls.ProgressBarWithTextControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Siemens.Simatic.S7.Webserver.API.WebApplicationManager.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Status text above progress bar -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding ProgressBarValue.StatusText}" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center" 
                   Margin="0,0,0,5"
                   FontWeight="SemiBold"/>
        
        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" Grid.Column="0"
                     Minimum="0" Maximum="100" 
                     Value="{Binding ProgressBarValue.Value}" 
                     Name="pbStatus" 
                     Height="25"/>
        
        <!-- Percentage text -->
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="{Binding ElementName=pbStatus, Path=Value, StringFormat={}{0:0}%}" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   Margin="10,0,0,0"
                   FontWeight="Bold"/>
    </Grid>
</UserControl>
